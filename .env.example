# agy-launch configuration
# Copyright (c) 2026 agy-launch contributors
# 仅供学习与研究使用；其他用途后果自负。
#
# Copy this file to one of:
#   ./.env                          # project-local (recommended when sharing a repo)
#   ~/.config/agy-launch/.env       # user-global (created by install.sh)
#   ~/.agy-launch.env
#
# Or set the same keys as real environment variables.
# For AGY_LAUNCH_* and AGY_BIN, higher-priority .env files override stale shell exports.
#
# Required:

# OpenAI-compatible API base (no trailing /chat/completions)
AGY_LAUNCH_BASE_URL=https://your-gateway.example/v1

# Model name sent to POST {BASE}/chat/completions
AGY_LAUNCH_MODEL=gemini-3.5-flash

# API Key Configuration: Specify either a single key via AGY_LAUNCH_API_KEY or multiple comma-separated keys via AGY_LAUNCH_API_KEYS for rotation.
AGY_LAUNCH_API_KEY=sk-your-key-here
# AGY_LAUNCH_API_KEYS=key1,key2,key3

# Optional:

# Model id passed to `agy --model` (must be a known agy allowlist id)
# AGY_LAUNCH_CLI_MODEL=gemini-3.5-flash-low

# Optional display name shown back to agy for the selected CLI model id.
# Useful when the upstream model is not actually Gemini.
# AGY_LAUNCH_MODEL_DISPLAY_NAME=gpt-4.1-mini

# Optional provider label for the selected CLI model metadata.
# Supported: google, openai, anthropic
# AGY_LAUNCH_MODEL_PROVIDER=openai

# Upstream HTTP User-Agent. Default is a curl-like value because some gateways
# reject Python's default urllib signature.
# AGY_LAUNCH_USER_AGENT=curl/8.5.0

# Upstream pacing / retry controls for gateways that return Cloudflare 429.
# Minimum spacing between requests across all proxy threads.
# AGY_LAUNCH_UPSTREAM_MIN_INTERVAL_SECONDS=0.25
# Extra retry attempts for retryable upstream failures after key rotation.
# AGY_LAUNCH_UPSTREAM_RETRIES=2
# Default per-key freeze after 429 when Retry-After is absent.
# AGY_LAUNCH_429_FREEZE_SECONDS=60
# Maximum cooldown honored from Retry-After or backoff.
# AGY_LAUNCH_MAX_RETRY_AFTER_SECONDS=300
# Retry backoff range for transient upstream failures.
# AGY_LAUNCH_BACKOFF_INITIAL_SECONDS=1
# AGY_LAUNCH_BACKOFF_MAX_SECONDS=30

# Default reasoning effort fallback ("low", "medium", "high" - only for reasoning models)
# AGY_LAUNCH_REASONING_EFFORT=

# Default maximum completion tokens / thinking limit
# AGY_LAUNCH_MAX_COMPLETION_TOKENS=

# Default maximum context length/tokens limit
# AGY_LAUNCH_MAX_TOKENS=

# Path to agy binary
# AGY_BIN=agy

# Force a specific .env file (highest priority)
# AGY_LAUNCH_ENV=/path/to/custom.env

# Log proxy requests
# AGY_LAUNCH_VERBOSE=1

# Write debug JSON dumps here (default: $TMPDIR/agy-launch)
# AGY_LAUNCH_DEBUG_DIR=/tmp/agy-launch

# Bind proxy to a fixed port (default: ephemeral)
# AGY_LAUNCH_PORT=0
